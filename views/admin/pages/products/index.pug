extends ../../layouts/default.pug

block main
  h1 Danh sách sản phẩm

  table.table.table-hover.table-sm
    thead
        tr
            th STT
            th Hình ảnh
            th Tiêu đề
            th Giá
            th Trạng thái
            th Hành động
    tbody
        tr
            td 1
            td
                img(
                    src="https://i.dummyjson.com/data/products/1/thumbnail.jpg"
                    alt="Sản phẩm 1"
                    width="100px"
                    height="auto"
                )

            td Sản phẩm 1
            td 1000$
            td
                span(class="badge bg-success") Còn hàng
            td(class="d-flex gap-2")
                button(type="button" class="btn btn-warning btn-sm") Sửa
                button(type="button" class="btn btn-danger btn-sm") Xóa

        tr
            td 2
            td
                img(
                    src="https://i.dummyjson.com/data/products/1/thumbnail.jpg"
                    alt="Sản phẩm 2"
                    width="100px"
                    height="auto"
                )

            td Sản phẩm 2
            td 1000$
            td
                span(class="badge bg-danger") Dừng kinh doanh
            td(class="d-flex gap-2")
                button(type="button" class="btn btn-warning btn-sm") Sửa
                button(type="button" class="btn btn-danger btn-sm") Xóa