extends ../../layouts/default.pug
include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug

block main
    h1 Danh sách sản phẩm
    .card.mb-3
        .card-header Bộ lọc và Tìm kiếm
        .card-body
            .d-flex.flex-wrap.align-items-center.gap-2
                .input-group.input-group-sm.flex-grow-1.me-2
                    +search()

                // Buttons for medium+ screens (wrap automatically when too many)
                .d-none.d-md-flex.flex-wrap.gap-2(
                    role="group" 
                    aria-label="Filter buttons"
                ) 
                    +filter-status(filterStatus)

                // Dropdown for small screens
                .dropdown.d-md-none
                    button.btn.btn-sm.btn-outline-secondary.dropdown-toggle(
                        type="button" 
                        id="filterDropdown" 
                        data-bs-toggle="dropdown" 
                        aria-expanded="false"
                    ) Lọc
                    ul.dropdown-menu(
                        aria-labelledby="filterDropdown"
                    )
                        each item in filterStatus
                            li
                                a.dropdown-item(
                                    href="#" 
                                    data-status=item.status
                                )= item.name

    .card.mb-3
        .card-header Danh sách
        .card-body

            +formChangeMulti(`${prefixAdmin}/products/change-multi`)
            table(
                class="table table-hover table-sm table-bordered"
                    checkbox-multi
            )
                thead
                    tr
                        th
                            input(type="checkbox" id="check-all")
                        th STT
                        th Hình ảnh
                        th Tiêu đề
                        th Giá
                        th Trạng thái
                        th Hành động
                tbody
                    each item, index in products
                        tr
                            td
                                input(
                                    type="checkbox" 
                                    name="id" 
                                    value=item.id
                                )
                            td= index + 1
                            td
                                if item && item.thumbnail
                                    img(src=item.thumbnail alt=item.title width="100px" height="auto")
                                else
                                    | -
                            td= item && item.title
                            td= item && item.price
                            td
                                if (item && item.status === "active")
                                    span(
                                        role="button"
                                        data-status=item.status
                                        data-id=item._id
                                        button-change-status
                                        class="badge bg-success"
                                    ) Còn hàng
                                else
                                    span(
                                        role="button"
                                        data-status=item.status
                                        data-id=item._id
                                        button-change-status
                                        class="badge bg-danger"
                                    ) Dừng kinh doanh
                            td(class="d-flex gap-2")
                                button(type="button" class="btn btn-warning btn-sm") Sửa
                                button(type="button" class="btn btn-danger btn-sm") Xóa

            //- Pagination (mixin)
            +pagination(pagination, baseQuery)

            form(
                action=""
                method="POST"
                id="form-change-status"
                data-path=`${prefixAdmin}/products/change-status/`
            )
                // include override field so server can treat POST as PATCH
                input(type="hidden" name="_method" value="PATCH")
            script(src="/admin/js/product.js")
            script(src="/admin/js/script.js")